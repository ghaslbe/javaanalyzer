  <input type="button" class="submitbutton" id="submitbutton" value="Hier klicken und unverbindlich anfragen" onclick="dosend();return false;">
  <div style="display:none"  id="response3" ><pre class="thankyoudiv">Vielen Dank</pre></div>

</form>

  </div>
</div>

