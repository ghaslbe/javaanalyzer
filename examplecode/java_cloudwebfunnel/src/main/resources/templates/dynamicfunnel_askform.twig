<input type="hidden" name="funneldata" value="{{elementdatax.funneldata}}">

<input type="hidden" name="utm_source" value="{{utm_source}}">
<input type="hidden" name="utm_campaign" value="{{utm_campaign}}">
<input type="hidden" name="utm_medium" value="{{utm_medium}}">
<input type="hidden" name="utm_content" value="{{utm_content}}">


<div class="formsubhead">
 {{elementdatax.radio.radioquestion}}<br>
</div>
 
<div class="rboxes">
{% for radiovalue in elementdatax.radio.elements %} 
  <label class="form-control">     <input type="radio" name="{{elementdatax.radio.radiokey}}" value="{{radiovalue}}"/>{{radiovalue}}</label>
  {% endfor %}
